TALK_TO_YOUR_STOCK_ENV=local
DEV_AUTH_USER_ID=00000000-0000-0000-0000-000000000001
DEV_AUTH_EMAIL=dev@example.com
AGENT_SERVICE_URL=http://agent-service:8001

# Required by production readiness for the Web BFF.
MANAGED_AUTH_JWKS_URL=
MANAGED_AUTH_ISSUER=
MANAGED_AUTH_AUDIENCE=

# Required by Agent Service production readiness and Comps internal calls.
GOOGLE_ADK_APP_NAME=
GOOGLE_API_KEY=
COMPS_SERVICE_URL=http://comps-service:8002
COMPS_SERVICE_INTERNAL_TOKEN=local-comps-service-token

# Required by Comps Service readiness.
ALPHA_VANTAGE_API_KEY=

# Only used by opt-in live Alpha Vantage tests, not service readiness.
# TODO: Set this to the same value as ALPHA_VANTAGE_API_KEY for now.
TEST_ALPHA_VANTAGE_API_KEY=
# Set to 1 only when intentionally running live Alpha Vantage tests.
RUN_LIVE_ALPHA_VANTAGE_TESTS=0
