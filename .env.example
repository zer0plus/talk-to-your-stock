# Google AI Studio Gemini API path for local development.
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=PASTE_YOUR_GOOGLE_AI_STUDIO_API_KEY
GEMINI_MODEL=gemini-3.1-flash-lite

# Alpha Vantage free API key for comps generation.
ALPHA_VANTAGE_API_KEY=PASTE_YOUR_ALPHA_VANTAGE_API_KEY

# Empty for free end-of-day GLOBAL_QUOTE. Premium can use delayed or realtime.
ALPHA_VANTAGE_QUOTE_ENTITLEMENT=
ALPHA_VANTAGE_MIN_REQUEST_INTERVAL_SECONDS=1.1
